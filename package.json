{
  "name": "@outclimb/root",
  "version": "1.0.0",
  "description": "General Web Service for everything OutClimb",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OutClimb/OutClimb.git"
  },
  "author": "Nichole Mattera",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/OutClimb/OutClimb/issues"
  },
  "homepage": "https://github.com/OutClimb/OutClimb#readme",
  "scripts": {
    "build": "pnpm run -r -F !@outclimb/root build",
    "build:form": "pnpm run -r -F @outclimb/form build",
    "build:manager": "pnpm run -r -F @outclimb/manager build",
    "build:watch": "pnpm run -r -F !@outclimb/root build:watch",
    "dev": "pnpm run -r -F !@outclimb/root dev",
    "dev:form": "pnpm run -r -F @outclimb/form dev",
    "dev:manager": "pnpm run -r -F @outclimb/manager dev",
    "format": "pnpm run -r -F !@outclimb/root format",
    "format:fix": "pnpm run -r -F !@outclimb/root format:fix",
    "lint": "pnpm run -r -F !@outclimb/root lint",
    "lint:fix": "pnpm run -r -F !@outclimb/root lint:fix",
    "preinstall": "npx only-allow pnpm",
    "preview": "pnpm run -r -F !@outclimb/root preview",
    "preview:form": "pnpm run -r -F @outclimb/form preview",
    "preview:manager": "pnpm run -r -F @outclimb/manager preview"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/eslint-plugin-query": "^5.101.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "lint-staged": {
    "packages/**/src/**/*.{css,html,js,jsx,scss,ts,tsx,vue}": [
      "oxfmt"
    ],
    "*.{json,md,yaml,yml}": [
      "oxfmt"
    ],
    "*.go": [
      "gofmt -w"
    ]
  },
  "engines": {
    "node": "24.16.0",
    "pnpm": "11.5.1"
  },
  "packageManager": "pnpm@11.5.1"
}
