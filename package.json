{
  "name": "@outclimb/root",
  "version": "1.0.0",
  "description": "General Web Service for everything OutClimb",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OutClimb/OutClimb.git"
  },
  "author": "Nichole Mattera",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/OutClimb/OutClimb/issues"
  },
  "homepage": "https://github.com/OutClimb/OutClimb#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:manager": "npm run build --workspace=@outclimb/manager",
    "dev": "npm run dev --workspaces",
    "dev:manager": "npm run dev --workspace=@outclimb/manager",
    "format": "npm run format --workspaces",
    "format:fix": "npm run format:fix --workspaces",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint:fix --workspaces",
    "preview": "npm run preview --workspaces",
    "preview:manager": "npm run preview --workspace=@outclimb/manager"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@tanstack/router-plugin": "^1.166.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.10"
  },
  "lint-staged": {
    "packages/**/src/**/*.{css,html,js,jsx,scss,ts,tsx,vue}": [
      "oxfmt"
    ],
    "*.{json,md,yaml,yml}": [
      "oxfmt"
    ],
    "*.go": [
      "gofmt -w"
    ]
  }
}
